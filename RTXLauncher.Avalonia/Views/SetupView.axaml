<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RTXLauncher.Avalonia.ViewModels"
             x:Class="RTXLauncher.Avalonia.Views.SetupView"
             x:DataType="vm:SetupViewModel">

	<ScrollViewer>
		<StackPanel Spacing="15" Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="600">

			<!-- ====================================================== -->
			<!-- WELCOME / FIRST-TIME INSTALL SCREEN                      -->
			<!-- ====================================================== -->
			<Border BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="20"
			        IsVisible="{Binding IsWelcomeVisible}">
				<StackPanel Spacing="15">
				<TextBlock Text="Welcome to the Garry's Mod RTX Launcher" FontSize="20" FontWeight="Bold" TextAlignment="Center" TextWrapping="Wrap"/>

				<!-- Pre-flight Warnings Area -->
				<ItemsControl ItemsSource="{Binding PreflightWarnings}"
				              IsVisible="{Binding ShowPreflightWarnings}">
					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<Border Background="#40FF0000" BorderBrush="Red" BorderThickness="1" CornerRadius="3" Padding="10" Margin="0,5">
								<TextBlock Text="{Binding}" TextWrapping="Wrap" Foreground="White"/>
							</Border>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>

				<TextBlock Text="This quick installer will automatically set up everything you need to play." TextWrapping="Wrap"/>

				<StackPanel Margin="20,5,0,5">
					<TextBlock Text="• Create a clean, separate copy of Garry's Mod."/>
					<TextBlock Text="• Download and install the latest recommended RTX Remix."/>
					<TextBlock Text="• Apply essential community fixes and patches."/>
					<TextBlock Text="• Configure optimal default settings."/>
				</StackPanel>

				<!-- Vanilla Installation Path -->
				<Separator Margin="0,10"/>
				<StackPanel Spacing="8">
					<TextBlock Text="Vanilla Garry's Mod Path:" FontWeight="SemiBold"/>
					<Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
						<Border Grid.Column="0" 
						        BorderBrush="Gray" 
						        BorderThickness="1" 
						        CornerRadius="3" 
						        Padding="8"
						        Background="#20000000">
							<TextBlock Text="{Binding AutoDetectedPath}" 
							           TextTrimming="CharacterEllipsis"
							           VerticalAlignment="Center"
							           ToolTip.Tip="{Binding AutoDetectedPath}"/>
						</Border>
						<Button Grid.Column="1" 
						        Content="Browse..." 
						        Command="{Binding BrowseVanillaPathCommand}"
						        VerticalAlignment="Stretch"
						        Width="100"/>
					</Grid>
					<TextBlock Text="{Binding ManualVanillaPath, StringFormat='Manual path: {0}'}" 
					           FontSize="11" 
					           Foreground="LightGreen"
					           IsVisible="{Binding ManualVanillaPath, Converter={x:Static ObjectConverters.IsNotNull}}"
					           TextWrapping="Wrap"/>
				</StackPanel>

				<!-- Release Channel Selection -->
			<StackPanel Spacing="8" Margin="0,10,0,0">
					<TextBlock Text="Release Channel:" FontWeight="SemiBold"/>
					<ComboBox ItemsSource="{Binding AvailableReleaseChannels}"
					          SelectedItem="{Binding SelectedReleaseChannel}"
					          HorizontalAlignment="Stretch"/>
				</StackPanel>

				<!-- Local Zip Overrides (collapsible) -->
				<Expander Header="Install from Local Zips (optional)" IsExpanded="False" Margin="0,10,0,0">
					<StackPanel Spacing="8" Margin="0,8,0,0">
						<TextBlock Text="Use local zip files instead of downloading from GitHub." FontSize="11" Opacity="0.7" TextWrapping="Wrap"/>

						<!-- RTX Remix local zip -->
						<Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" RowDefinitions="Auto">
							<CheckBox Grid.Column="0" IsChecked="{Binding UseLocalRemixZip}" Content="RTX Remix" VerticalAlignment="Center"/>
							<TextBlock Grid.Column="1" 
							           Text="{Binding LocalRemixZipPath, FallbackValue='No file selected'}" 
							           TextTrimming="CharacterEllipsis" 
							           VerticalAlignment="Center" 
							           Opacity="0.7"
							           FontSize="11"
							           ToolTip.Tip="{Binding LocalRemixZipPath}"/>
							<Button Grid.Column="2" Content="Browse..." 
							        Command="{Binding BrowseLocalRemixZipCommand}" 
							        Width="80" Padding="4,2"/>
						</Grid>

						<!-- Binary Patches local zip -->
						<Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" RowDefinitions="Auto">
							<CheckBox Grid.Column="0" IsChecked="{Binding UseLocalPatchesZip}" Content="Binary Patches" VerticalAlignment="Center"/>
							<TextBlock Grid.Column="1" 
							           Text="{Binding LocalPatchesZipPath, FallbackValue='No file selected'}" 
							           TextTrimming="CharacterEllipsis" 
							           VerticalAlignment="Center" 
							           Opacity="0.7"
							           FontSize="11"
							           ToolTip.Tip="{Binding LocalPatchesZipPath}"/>
							<Button Grid.Column="2" Content="Browse..." 
							        Command="{Binding BrowseLocalPatchesZipCommand}" 
							        Width="80" Padding="4,2"/>
						</Grid>

						<!-- Fixes Package local zip -->
						<Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" RowDefinitions="Auto">
							<CheckBox Grid.Column="0" IsChecked="{Binding UseLocalFixesZip}" Content="Fixes Package" VerticalAlignment="Center"/>
							<TextBlock Grid.Column="1" 
							           Text="{Binding LocalFixesZipPath, FallbackValue='No file selected'}" 
							           TextTrimming="CharacterEllipsis" 
							           VerticalAlignment="Center" 
							           Opacity="0.7"
							           FontSize="11"
							           ToolTip.Tip="{Binding LocalFixesZipPath}"/>
							<Button Grid.Column="2" Content="Browse..." 
							        Command="{Binding BrowseLocalFixesZipCommand}" 
							        Width="80" Padding="4,2"/>
						</Grid>
					</StackPanel>
				</Expander>

				<Separator Margin="0,10"/>

				<Button Content="Start Quick Install"
				        Command="{Binding RunInstallCommand}"
				        IsEnabled="{Binding !IsBusy}"
				        HorizontalAlignment="Stretch"
				        Classes="accent"
				        Padding="10"
				        FontSize="16"/>
				</StackPanel>
			</Border>

			<!-- ====================================================== -->
			<!-- INSTALLATION COMPLETED SCREEN                            -->
			<!-- ====================================================== -->
			<Border BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="20"
			        IsVisible="{Binding IsCompletedVisible}">
				<StackPanel Spacing="15">
					<TextBlock Text="Garry's Mod RTX is Installed!" FontSize="20" FontWeight="Bold" Foreground="LightGreen" TextAlignment="Center" TextWrapping="Wrap"/>
					<TextBlock Text="Your installation is ready. Here's what you can do now:" TextWrapping="Wrap" HorizontalAlignment="Center"/>

					<StackPanel Margin="20,5,0,5" HorizontalAlignment="Center">
						<TextBlock Text="• Use the 'Launch Game' button to play."/>
						<TextBlock Text="• Visit the 'Settings' tab to change resolution."/>
						<TextBlock Text="• Go to 'Mounting' to add content from other games."/>
					</StackPanel>

					<Separator Margin="0,10"/>

					<TextBlock Text="If you need to repair or update your installation, you can run the installer again." TextWrapping="Wrap" Opacity="0.7"/>

					<Button Content="Reinstall"
					        Command="{Binding ReRunQuickInstallCommand}"
					        IsEnabled="{Binding !IsBusy}"
					        HorizontalAlignment="Stretch"/>
				</StackPanel>
			</Border>

		</StackPanel>
	</ScrollViewer>
</UserControl>